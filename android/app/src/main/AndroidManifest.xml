<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Active network services layer (Interface Info, DNS Lookup, Port Scan). -->
    <!-- INTERNET: TCP connect scan + DNS-over-HTTPS queries. -->
    <uses-permission android:name="android.permission.INTERNET"/>
    <!-- ACCESS_NETWORK_STATE: read connectivity / interface state. -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE"/>
    <!-- ACCESS_WIFI_STATE: read Wi-Fi link details via network_info_plus, and
         read the nearby-AP scan results via WifiManager.getScanResults()
         (Nearby AP Scan, H3). -->
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE"/>
    <!-- CHANGE_WIFI_STATE: lets the Nearby AP Scan tool (H3) request a fresh
         scan via WifiManager.startScan(). The OS rate-limits startScan() on
         Android 9+; when throttled, getScanResults() still returns the last
         cached scan, so the tool degrades to "showing the last scan" rather
         than failing (see MainActivity.readScanResults). -->
    <uses-permission android:name="android.permission.CHANGE_WIFI_STATE"/>
    <!-- Reading the connected SSID/BSSID on Android 8.0+ requires a location
         permission at runtime; network_info_plus surfaces null without it and
         the UI shows "Not available" rather than crashing. -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION"/>
    <!-- SPIKE-HSD-01: CHANGE_WIFI_MULTICAST_STATE lets the app acquire a Wi-Fi
         multicast lock. Without an active multicast lock, Android drops
         inbound multicast frames to save power, so the mDNS/Bonjour browse
         (multicast_dns over UDP/5353) returns nothing. The lock is acquired in
         the MainActivity for the duration of a scan (see MainActivity.kt). -->
    <uses-permission android:name="android.permission.CHANGE_WIFI_MULTICAST_STATE"/>
    <!-- SPIKE-HSD-01 Gate 3: ACCESS_LOCAL_NETWORK is the NEW gating permission
         for ALL local-network traffic (TCP connect-scan, mDNS, reverse DNS to
         LAN). Per the Android local-network-permission model it is opt-in on
         Android 16 (NEARBY_WIFI_DEVICES) and becomes MANDATORY on Android 17+
         for apps targeting SDK 37+. Without the grant the connect-scan fails
         with TCP timeouts / EPERM. DATE-SENSITIVE: re-verify the SDK-37 /
         Android-17 enforcement timing at spike time — Google has shifted these
         dates before. This declaration is harmless on older SDKs (ignored).
         Keith validates the request-flow timing on a current-SDK device. -->
    <uses-permission android:name="android.permission.ACCESS_LOCAL_NETWORK"/>
    <application
        android:label="WLAN Pros Toolbox"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            <!-- Specifies an Android theme to apply to this Activity as soon as
                 the Android process has started. This theme is visible to the user
                 while the Flutter UI initializes. After that, this theme continues
                 to determine the Window background behind the Flutter UI. -->
            <meta-data
              android:name="io.flutter.embedding.android.NormalTheme"
              android:resource="@style/NormalTheme"
              />
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>
        <!-- Don't delete the meta-data below.
             This is used by the Flutter tool to generate GeneratedPluginRegistrant.java -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />
    </application>
    <!-- Required to query activities that can process text, see:
         https://developer.android.com/training/package-visibility and
         https://developer.android.com/reference/android/content/Intent#ACTION_PROCESS_TEXT.

         In particular, this is used by the Flutter engine in io.flutter.plugin.text.ProcessTextPlugin. -->
    <queries>
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT"/>
            <data android:mimeType="text/plain"/>
        </intent>
    </queries>
</manifest>
