<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Export compliance: the app uses only standard HTTPS (TLS) for its
	     network tools — DNS-over-HTTPS, keyless HTTPS API lookups, and TCP
	     sockets. No proprietary or non-standard cryptography. Declaring this
	     here marks the app as exempt so App Store Connect does not prompt for
	     an encryption questionnaire on every upload. -->
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIconFile</key>
	<string></string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundleDisplayName</key>
	<string>WLAN Pros Toolbox</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(FLUTTER_BUILD_NAME)</string>
	<key>CFBundleVersion</key>
	<string>$(FLUTTER_BUILD_NUMBER)</string>
	<key>LSMinimumSystemVersion</key>
	<string>$(MACOSX_DEPLOYMENT_TARGET)</string>
	<key>NSHumanReadableCopyright</key>
	<string>$(PRODUCT_COPYRIGHT)</string>
	<key>NSLocationUsageDescription</key>
	<string>WLAN Pros Toolbox uses your location to read the connected Wi-Fi network name (SSID and BSSID), which macOS gates behind this permission, and to fill in your current latitude and longitude in the Lat / Long tool. If your device cannot get a position fix, the app can estimate an approximate city-level location from your public IP instead. When you use the map, your coordinates are sent to OpenStreetMap to load the map tiles. Your location is not stored by us and is never used for tracking or advertising.</string>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>WLAN Pros Toolbox uses your location to read the connected Wi-Fi network name (SSID and BSSID), which macOS gates behind this permission, and to fill in your current latitude and longitude in the Lat / Long tool. If your device cannot get a position fix, the app can estimate an approximate city-level location from your public IP instead. When you use the map, your coordinates are sent to OpenStreetMap to load the map tiles. Your location is not stored by us and is never used for tracking or advertising.</string>
	<key>NSMainNibFile</key>
	<string>MainMenu</string>
	<key>NSPrincipalClass</key>
	<string>NSApplication</string>
	<!-- The in-house native NWBrowser channel (macos/Runner/MdnsBrowseChannel.swift)
	     drives the macOS Bonjour daemon for the SPIKE-HSD-01 LAN-discovery mDNS
	     pass. macOS requires every browsed DNS-SD service type to be declared in
	     NSBonjourServices or the native browser returns nothing — this array MUST
	     stay in lockstep with kBrowsedServiceTypes in mdns_browse.dart and with
	     the iOS Info.plist. -->
	<key>NSBonjourServices</key>
	<array>
		<string>_services._dns-sd._udp</string>
		<string>_http._tcp</string>
		<string>_https._tcp</string>
		<string>_airplay._tcp</string>
		<string>_raop._tcp</string>
		<string>_ipp._tcp</string>
		<string>_ipps._tcp</string>
		<string>_printer._tcp</string>
		<string>_pdl-datastream._tcp</string>
		<string>_companion-link._tcp</string>
		<string>_googlecast._tcp</string>
		<string>_sonos._tcp</string>
		<string>_spotify-connect._tcp</string>
		<string>_smb._tcp</string>
		<string>_ssh._tcp</string>
		<string>_device-info._tcp</string>
		<string>_workstation._tcp</string>
	</array>
	<!-- macOS gates Local Network access (which the native Bonjour browse uses)
	     behind a usage-description string + a user prompt. Without it the mDNS
	     browse silently yields nothing on a sandboxed macOS build. The sandbox
	     network.client entitlement is already declared in *.entitlements. -->
	<key>NSLocalNetworkUsageDescription</key>
	<string>WLAN Pros Toolbox uses the local network to discover devices (printers, speakers, media players) on your Wi-Fi for the LAN discovery tool. Nothing is stored or shared.</string>
</dict>
</plist>
