default_platform(:ios)

# App Store Connect API key (identifiers from gitignored fastlane/.env; the
# private .p8 lives outside the repo). Used for signing and TestFlight upload
# with no interactive Apple ID login.
def asc_api_key
  app_store_connect_api_key(
    key_id: ENV["ASC_KEY_ID"],
    issuer_id: ENV["ASC_ISSUER_ID"],
    key_filepath: ENV["ASC_KEY_FILEPATH"],
    in_house: false
  )
end

APP_ID = "com.wlanpros.wlanProsToolbox".freeze
APP_NAME = "WLAN Pros Toolbox".freeze
TEAM_ID = "MNMCTY7YZT".freeze
INTERNAL_GROUP = "Field Testers".freeze

platform :ios do
  desc "Non-mutating: verify API auth, app record, bundle id, and distribution certs"
  lane :check do
    asc_api_key

    app = Spaceship::ConnectAPI::App.find(APP_ID)
    app ? UI.success("APP RECORD: #{app.name} | #{app.bundle_id} | id=#{app.id}") : UI.important("APP RECORD NOT FOUND")

    bundle = Spaceship::ConnectAPI::BundleId.all.find { |b| b.identifier == APP_ID }
    bundle ? UI.success("BUNDLE ID: #{bundle.identifier} | id=#{bundle.id}") : UI.important("BUNDLE ID NOT registered")

    certs = Spaceship::ConnectAPI::Certificate.all.select { |c| c.certificate_type.to_s.include?("DISTRIBUTION") }
    UI.message("Distribution certificates: #{certs.size}")

    next unless app
    app.get_beta_groups.each do |g|
      builds = (g.fetch_builds rescue [])
      testers = (Spaceship::ConnectAPI::BetaTester.all(filter: { "betaGroups" => g.id }) rescue [])
      UI.message("Group '#{g.name}' internal=#{g.is_internal_group} testers=#{testers.size} builds=#{builds.map(&:version).join(',')}")
    end
  end

  desc "Register the App ID and create the App Store Connect app record (idempotent)"
  lane :make_app do
    asc_api_key

    bundle = Spaceship::ConnectAPI::BundleId.all.find { |b| b.identifier == APP_ID }
    bundle ||= Spaceship::ConnectAPI::BundleId.create(name: APP_NAME, identifier: APP_ID, platform: Spaceship::ConnectAPI::BundleIdPlatform::IOS)
    UI.success("Bundle ID ready: #{bundle.identifier}")

    app = Spaceship::ConnectAPI::App.find(APP_ID)
    if app
      UI.success("App record already exists: #{app.name}")
    else
      # NOTE: the App Store Connect API does NOT allow creating an app record;
      # this will raise. Create it once via the App Store Connect website
      # (Apps -> + -> New App), then everything else here is automated.
      app = Spaceship::ConnectAPI::App.create(
        name: APP_NAME, version_string: "1.0.0", sku: "wlanprostoolbox",
        primary_locale: "en-US", bundle_id: APP_ID,
        platforms: [Spaceship::ConnectAPI::Platform::IOS]
      )
      UI.success("Created app record: #{app.name}")
    end
  end

  desc "Generate the distribution certificate and App Store provisioning profile"
  lane :signing do
    api_key = asc_api_key
    cert(api_key: api_key, development: false)
    sigh(api_key: api_key, app_identifier: APP_ID, adhoc: false, force: false)
  end

  desc "Upload the already-built ipa to TestFlight (waits for processing)"
  lane :upload do
    api_key = asc_api_key
    upload_to_testflight(
      api_key: api_key,
      ipa: File.expand_path("../../build/ios/ipa/wlan_pros_toolbox.ipa", __dir__),
      skip_submission: true,
      skip_waiting_for_build_processing: false,
      distribute_external: false,
      changelog: "Internal field-testing build (Wi-Fi + Network tools)."
    )
  end

  desc "Ensure the internal '#{INTERNAL_GROUP}' group exists (access to all builds). " \
       "Adding the account holder as a tester must be done once on the website."
  lane :internal_group do
    asc_api_key
    app = Spaceship::ConnectAPI::App.find(APP_ID)
    UI.user_error!("App record not found — create it on the website first") unless app

    group = app.get_beta_groups.find { |g| g.name == INTERNAL_GROUP }
    if group
      UI.success("Internal group '#{INTERNAL_GROUP}' already exists")
    else
      # The create_beta_group helper hardcodes public-link attributes that Apple
      # rejects on internal groups, so POST the minimal body directly.
      body = {
        data: {
          type: "betaGroups",
          attributes: { name: INTERNAL_GROUP, isInternalGroup: true, hasAccessToAllBuilds: true },
          relationships: { app: { data: { id: app.id, type: "apps" } } }
        }
      }
      Spaceship::ConnectAPI.test_flight_request_client.post("v1/betaGroups", body)
      UI.success("Created internal group '#{INTERNAL_GROUP}'")
    end
    UI.message("Add yourself once: App Store Connect -> TestFlight -> Internal Testing -> " \
               "#{INTERNAL_GROUP} -> + -> check your name. Future builds auto-distribute.")
  end

  EXTERNAL_GROUP = "WLAN Field Testers".freeze

  desc "Create the invite-only EXTERNAL TestFlight group (email invites, no public link)"
  lane :external_group do
    asc_api_key
    app = Spaceship::ConnectAPI::App.find(APP_ID)
    UI.user_error!("App record not found") unless app

    group = app.get_beta_groups.find { |g| g.name == EXTERNAL_GROUP }
    if group
      UI.success("External group '#{EXTERNAL_GROUP}' already exists (internal=#{group.is_internal_group})")
    else
      # External groups DO allow the public-link attributes; keep the link OFF so
      # the group is invite-by-email only.
      group = app.create_beta_group(
        group_name: EXTERNAL_GROUP,
        is_internal_group: false,
        public_link_enabled: false
      )
      UI.success("Created invite-only external group '#{EXTERNAL_GROUP}'")
    end
    UI.message("Invite people with: INVITE_EMAILS='a@x.com,b@y.com' fastlane invite_external")
    UI.message("External testers can install only after the build passes Beta App Review.")
  end

  desc "Invite external testers by email. Pass INVITE_EMAILS='a@x.com,b@y.com'"
  lane :invite_external do
    asc_api_key
    app = Spaceship::ConnectAPI::App.find(APP_ID)
    group = app.get_beta_groups.find { |g| g.name == EXTERNAL_GROUP }
    UI.user_error!("Run external_group first") unless group

    # Each entry is "email" or "email|First|Last" (names recommended for invites).
    entries = (ENV["INVITE_EMAILS"] || "").split(",").map(&:strip).reject(&:empty?)
    UI.user_error!("No emails. Use INVITE_EMAILS='a@x.com|First|Last,...' fastlane invite_external") if entries.empty?

    entries.each do |entry|
      email, first, last = entry.split("|").map(&:strip)
      first = (first && !first.empty?) ? first : email.split("@").first
      last  = (last && !last.empty?) ? last : "Tester"
      begin
        Spaceship::ConnectAPI.post_beta_tester_assignment(
          beta_group_ids: [group.id],
          attributes: { email: email, firstName: first, lastName: last }
        )
        UI.success("Invited #{first} #{last} <#{email}> to '#{EXTERNAL_GROUP}'")
      rescue => e
        e.message =~ /already|exist/i ? UI.important("#{email} already invited") : UI.error("#{email}: #{e.message}")
      end
    end
  end

  desc "Distribute the latest build to the external group and submit for Beta App Review"
  # fastlane's pilot distribute_only has a known bug setting the Beta App
  # Description, so set Test Information + submit directly via the ConnectAPI.
  lane :submit_external_review do
    asc_api_key
    client = Spaceship::ConnectAPI
    app = client::App.find(APP_ID)
    group = app.get_beta_groups.find { |g| g.name == EXTERNAL_GROUP }
    UI.user_error!("Run external_group first") unless group
    latest = app.get_builds(limit: 200).max_by { |b| b.version.to_i }
    UI.user_error!("No build found to submit") unless latest

    desc_text = "WLAN Pros Toolbox: Wi-Fi and network diagnostic tools, RF calculators, " \
                "and reference tables for wireless professionals. Field testing the live " \
                "network diagnostics (signal, network quality, ping, traceroute)."

    # Test Information — beta app localization (description + feedback email).
    locs = app.get_beta_app_localizations
    loc = locs.find { |l| l.locale == "en-US" } || locs.first
    if loc
      client.patch_beta_app_localizations(localization_id: loc.id,
        attributes: { description: desc_text, feedbackEmail: "keith@wlanpros.com" })
    else
      client.post_beta_app_localizations(app_id: app.id,
        attributes: { locale: "en-US", description: desc_text, feedbackEmail: "keith@wlanpros.com" })
    end
    UI.success("Set beta Test Information")

    # Review contact (no demo account — the app has no login).
    client.patch_beta_app_review_detail(app_id: app.id, attributes: {
      contactFirstName: "Keith", contactLastName: "Parsons",
      contactEmail: "keith@wlanpros.com", contactPhone: "801-318-5522",
      demoAccountRequired: false
    })
    UI.success("Set Beta App Review contact")

    # Attach the build to the external group, then submit for review.
    latest.add_beta_groups(beta_groups: [group]) rescue nil
    begin
      client.post_beta_app_review_submissions(build_id: latest.id)
      UI.success("Submitted build #{latest.version} for Beta App Review")
    rescue => e
      e.message =~ /already|exist|state/i ? UI.important("Build #{latest.version} already in review: #{e.message}") : raise
    end
  end
end
