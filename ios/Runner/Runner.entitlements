<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- TICKET-01 SPIKE: App Group shared between the Runner app and the App
	     Intents execution context, so the Shortcuts receiver intent can hand the
	     harvested Wi-Fi JSON to the running Flutter engine via shared
	     UserDefaults + a Darwin notification. Must match
	     ShortcutsBridge.appGroupID. -->
	<key>com.apple.security.application-groups</key>
	<array>
		<string>group.com.wlanpros.wlanProsToolbox</string>
	</array>
	<!-- TICKET-BATCH7: Access Wi-Fi Information entitlement. Required to read the
	     connected network's security type and BSSID via NEHotspotNetwork
	     (WifiSecurityChannel.swift). Paired with Location-When-In-Use at runtime.
	     NEW ENTITLEMENT — needs an App Store justification at submission:
	     "The app reads the connected Wi-Fi network's security type and AP vendor
	     (from the BSSID's IEEE OUI) on-device, to help users understand their
	     own Wi-Fi link. The data is shown to the user and never collected or
	     transmitted." Apple must enable this capability on the App ID. -->
	<key>com.apple.developer.networking.wifi-info</key>
	<true/>
</dict>
</plist>
