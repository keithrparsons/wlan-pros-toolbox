<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CADisableMinimumFrameDurationOnPhone</key>
	<true/>
	<!-- Active network tools (Interface Info, Port Scan, future Ping/iperf)
	     touch hosts on the local network. iOS 14+ requires this purpose
	     string before granting local-network access. -->
	<key>NSLocalNetworkUsageDescription</key>
	<string>WLAN Pros Toolbox scans and inspects devices on your local network to report interface details, open ports, and connectivity.</string>
	<!-- Real ICMP Ping (icmp_ping_screen) sends ICMP echo via SimplePing
	     (dart_ping_ios). iOS 14+ requires both NSLocalNetworkUsageDescription
	     (above) and a Bonjour-services declaration before it will grant the
	     local-network access an ICMP socket to a LAN host needs. These wildcard
	     entries cover the generic service discovery SimplePing performs for
	     local targets. DEVICE-PENDING: this entitlement chain can only be
	     exercised against a provisioned device. -->
	<key>NSBonjourServices</key>
	<array>
		<string>_services._dns-sd._udp</string>
		<string>_http._tcp</string>
	</array>
	<!-- network_info_plus reads the connected Wi-Fi SSID/BSSID, which iOS
	     gates behind Location When In Use. Without this the SSID/BSSID fields
	     return null and the UI shows "Not available" rather than the network
	     name. -->
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>WLAN Pros Toolbox uses your location only to read the name (SSID) of the Wi-Fi network you are connected to. Your location is never stored or shared.</string>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>Wlan Pros Toolbox</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>wlan_pros_toolbox</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(FLUTTER_BUILD_NAME)</string>
	<key>CFBundleSignature</key>
	<string>????</string>
	<key>CFBundleVersion</key>
	<string>$(FLUTTER_BUILD_NUMBER)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UIApplicationSceneManifest</key>
	<dict>
		<key>UIApplicationSupportsMultipleScenes</key>
		<false/>
		<key>UISceneConfigurations</key>
		<dict>
			<key>UIWindowSceneSessionRoleApplication</key>
			<array>
				<dict>
					<key>UISceneClassName</key>
					<string>UIWindowScene</string>
					<key>UISceneConfigurationName</key>
					<string>flutter</string>
					<key>UISceneDelegateClassName</key>
					<string>$(PRODUCT_MODULE_NAME).SceneDelegate</string>
					<key>UISceneStoryboardFile</key>
					<string>Main</string>
				</dict>
			</array>
		</dict>
	</dict>
	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
</dict>
</plist>
