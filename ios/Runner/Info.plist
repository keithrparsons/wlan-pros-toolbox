<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CADisableMinimumFrameDurationOnPhone</key>
	<true/>
	<!-- Export compliance: the app uses only standard HTTPS (TLS) for its
	     network tools — DNS-over-HTTPS, keyless HTTPS API lookups, and TCP
	     sockets. No proprietary or non-standard cryptography. Declaring this
	     here marks the app as exempt so App Store Connect does not prompt for
	     an encryption questionnaire on every upload. -->
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
	<!-- Active network tools (Interface Info, Port Scan, future Ping/iperf)
	     touch hosts on the local network. iOS 14+ requires this purpose
	     string before granting local-network access. -->
	<key>NSLocalNetworkUsageDescription</key>
	<string>WLAN Pros Toolbox scans and inspects devices on your local network to report interface details, open ports, and connectivity.</string>
	<!-- Real ICMP Ping (icmp_ping_screen) sends ICMP echo via SimplePing
	     (dart_ping_ios). iOS 14+ requires both NSLocalNetworkUsageDescription
	     (above) and a Bonjour-services declaration before it will grant the
	     local-network access an ICMP socket to a LAN host needs. These wildcard
	     entries cover the generic service discovery SimplePing performs for
	     local targets. DEVICE-PENDING: this entitlement chain can only be
	     exercised against a provisioned device. -->
	<!-- SPIKE-HSD-01: the mDNS/Bonjour browse in the LAN Discovery prototype
	     (lib/services/network/lan_discovery/mdns_browse.dart) returns EMPTY on
	     iOS unless every browsed service type is declared here (brief
	     anti-pattern #3). This array MUST stay in lockstep with
	     kBrowsedServiceTypes in mdns_browse.dart. The first two entries also
	     cover the existing ICMP Ping / service-discovery use. DEVICE-PENDING:
	     this is Gate 1 — Keith confirms on a provisioned device that the
	     browse returns results with these declared. -->
	<key>NSBonjourServices</key>
	<array>
		<string>_services._dns-sd._udp</string>
		<string>_http._tcp</string>
		<string>_https._tcp</string>
		<string>_airplay._tcp</string>
		<string>_raop._tcp</string>
		<string>_ipp._tcp</string>
		<string>_ipps._tcp</string>
		<string>_printer._tcp</string>
		<string>_pdl-datastream._tcp</string>
		<string>_companion-link._tcp</string>
		<string>_googlecast._tcp</string>
		<string>_sonos._tcp</string>
		<string>_spotify-connect._tcp</string>
		<string>_smb._tcp</string>
		<string>_ssh._tcp</string>
		<string>_device-info._tcp</string>
		<string>_workstation._tcp</string>
	</array>
	<!-- Two Location consumers, both When-In-Use:
	     1. network_info_plus reads the connected Wi-Fi SSID/BSSID, which iOS
	        gates behind Location When In Use (without this the SSID/BSSID fields
	        return null and the UI shows "Not available").
	     2. geolocator reads the device's latitude/longitude/altitude for the
	        Lat / Long tool's "Use my location" affordance.
	     Location is used only on-device for these readings and is never stored
	     or shared. -->
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>WLAN Pros Toolbox uses your location to read the name (SSID) of the Wi-Fi network you are connected to, and to fill in your current latitude and longitude in the Lat / Long tool. When you use the map, your coordinates are sent to OpenStreetMap to load the map tiles. Your location is not stored by us and is never used for tracking or advertising.</string>
	<!-- LSApplicationQueriesSchemes lets the app open the Shortcuts app via the
	     PLAIN, fire-and-forget `shortcuts://run-shortcut?name=…` URL on iOS 9+
	     (UIApplication.canOpenURL / open both consult this allow-list). This is
	     the Live streaming trigger; it is NOT the x-callback form, so there is no
	     return URL scheme to register — the former wlanprostoolbox:// callback
	     CFBundleURLTypes entry was removed with the snapshot one-tap trigger. -->
	<key>LSApplicationQueriesSchemes</key>
	<array>
		<string>shortcuts</string>
	</array>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>WLAN Pros Toolbox</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>wlan_pros_toolbox</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(FLUTTER_BUILD_NAME)</string>
	<key>CFBundleSignature</key>
	<string>????</string>
	<key>CFBundleVersion</key>
	<string>$(FLUTTER_BUILD_NUMBER)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UIApplicationSceneManifest</key>
	<dict>
		<key>UIApplicationSupportsMultipleScenes</key>
		<false/>
		<key>UISceneConfigurations</key>
		<dict>
			<key>UIWindowSceneSessionRoleApplication</key>
			<array>
				<dict>
					<key>UISceneClassName</key>
					<string>UIWindowScene</string>
					<key>UISceneConfigurationName</key>
					<string>flutter</string>
					<key>UISceneDelegateClassName</key>
					<string>$(PRODUCT_MODULE_NAME).SceneDelegate</string>
					<key>UISceneStoryboardFile</key>
					<string>Main</string>
				</dict>
			</array>
		</dict>
	</dict>
	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
</dict>
</plist>
