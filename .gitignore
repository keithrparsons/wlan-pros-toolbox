# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store

# --- spike/iperf3-ffi: vendored upstream source + build artifacts (do NOT commit) ---
# We commit only third_party/iperf3/fetch_and_build.sh + README; everything it
# downloads/extracts/compiles is reproducible and stays out of git.
third_party/iperf3/iperf-*/
third_party/iperf3/*.tar.gz
third_party/iperf3/*.a
third_party/iperf3/*.dylib
third_party/iperf3/build/
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release
