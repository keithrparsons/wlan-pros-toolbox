# Miscellaneous
*.class
*.log
*.pyc

# fastlane auto-generated run artifacts (regenerate on every run)
android/fastlane/README.md
android/fastlane/report.xml
ios/fastlane/README.md
ios/fastlane/report.xml
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
# Generated build artifacts inside packages (the vendored web/pdfjs/build is kept on purpose)
packages/*/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Flutter golden-test failure diffs (transient)
test/**/failures/

# Secrets / signing material — never commit (preventive control, none present).
# No legitimately-needed .pem/.key exists in the tree at build time: SSL-inspect
# handles PEM strings in-memory, and the iperf3 src/*.pem are upstream test
# fixtures that are untracked. If a real build secret is ever needed, add a
# narrow negation (e.g. !path/to/needed.pem) rather than loosening this.
*.pem
*.key
*.p12
*.mobileprovision
*.jks
*.keystore
key.properties
.env
